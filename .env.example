# Birdeye Token Safety Radar - Environment Variables

# Required: Birdeye API Key (https://birdeye.so)
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Optional: Groq API Key for AI-powered insights (https://console.groq.com)
# If not set, rule-based fallback insights are generated instead
GROQ_API_KEY=your_groq_api_key_here
