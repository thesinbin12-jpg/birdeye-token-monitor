{
  "version": 2,
  "builds": [
    { "src": "index.py", "use": "@vercel/python", "config": { "maxDuration": 60 } },
    { "src": "static/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/api/(.*)", "dest": "index.py" },
    { "src": "/", "dest": "index.py" }
  ]
}
